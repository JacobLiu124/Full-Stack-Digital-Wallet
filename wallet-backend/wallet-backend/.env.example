# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Keep this secret — never expose to frontend

# ── Basiq (Australian open banking) ──────────────────────────────────────────
# Sign up at: basiq.io → create application → copy API key
BASIQ_API_KEY=your-basiq-api-key
BASIQ_BASE_URL=https://au-api.basiq.io

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────────────────
# Your Vercel frontend URL — add preview URLs if needed
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
